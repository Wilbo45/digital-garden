<canvas class="brain-canvas" id="brain-canvas" aria-hidden="true"></canvas>

<script>
(function () {
  const canvas = document.getElementById('brain-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  // ── Config ───────────────────────────────────────────────────────
  const MAX_DEPTH   = 7;      // recursion depth
  const DRAW_SPEED  = 0.038;  // progress per frame (controls drawing speed)
  const TRUNK_WIDTH = 3.8;    // root line width (px)
  const MIN_LEN     = 13;     // prune branches shorter than this (px)
  const SPREAD_BASE = 0.54;   // angular spread between siblings (radians)
  const LEN_DECAY   = 0.70;   // child length as fraction of parent
  const NUM_PRIMARY = 10;     // primary trunk branches from stem
  const RESTART_MS  = 1800;   // pause before redrawing (ms)

  // ── Brain silhouette (lateral, frontal pole right) ───────────────
  function makeBrainPath(W: number, H: number): Path2D {
    const cx = W * 0.50, cy = H * 0.44;
    const sx = W * 0.43, sy = H * 0.41;
    const p = new Path2D();
    p.moveTo(cx + sx * 0.30, cy + sy * 0.54);
    p.bezierCurveTo(cx + sx * 0.52, cy + sy * 0.24,  cx + sx * 0.70, cy - sy * 0.14,  cx + sx * 0.52, cy - sy * 0.56);
    p.bezierCurveTo(cx + sx * 0.28, cy - sy * 0.82,  cx - sx * 0.06, cy - sy * 0.86,  cx - sx * 0.38, cy - sy * 0.70);
    p.bezierCurveTo(cx - sx * 0.68, cy - sy * 0.52,  cx - sx * 0.82, cy - sy * 0.20,  cx - sx * 0.80, cy + sy * 0.10);
    p.bezierCurveTo(cx - sx * 0.76, cy + sy * 0.34,  cx - sx * 0.62, cy + sy * 0.44,  cx - sx * 0.50, cy + sy * 0.45);
    p.bezierCurveTo(cx - sx * 0.60, cy + sy * 0.74,  cx - sx * 0.30, cy + sy * 0.88,  cx - sx * 0.04, cy + sy * 0.78);
    p.bezierCurveTo(cx + sx * 0.04, cy + sy * 0.86,  cx + sx * 0.16, cy + sy * 0.88,  cx + sx * 0.16, cy + sy * 0.76);
    p.bezierCurveTo(cx + sx * 0.22, cy + sy * 0.64,  cx + sx * 0.26, cy + sy * 0.56,  cx + sx * 0.30, cy + sy * 0.54);
    p.closePath();
    return p;
  }

  // ── Rainbow hue from position ─────────────────────────────────────
  // right=240 (blue), top=120 (green/teal), left=60 (yellow), lower-right=300 (pink)
  function posToHue(x: number, y: number, cx: number, cy: number): number {
    const deg = Math.atan2(-(y - cy), x - cx) * 180 / Math.PI;
    return ((240 - deg) + 360) % 360;
  }

  // ── Types ─────────────────────────────────────────────────────────
  interface Branch {
    x0: number; y0: number;
    x1: number; y1: number;
    cpx: number; cpy: number;
    hue:      number;
    width:    number;
    progress: number;
    active:   boolean;
    done:     boolean;
    isLeaf:   boolean;
    children: Branch[];
  }

  // ── State ─────────────────────────────────────────────────────────
  let branches:  Branch[]  = [];
  let brainPath: Path2D;
  let bCx = 0, bCy = 0, W = 0, H = 0;
  let raf = 0, doneAt = -1;

  // ── Recursive tree builder ────────────────────────────────────────
  function grow(
    x0: number, y0: number, angle: number, len: number,
    depth: number, parent: Branch | null
  ): Branch | null {
    if (depth > MAX_DEPTH || len < MIN_LEN) return null;

    // Binary-search longest valid length staying inside silhouette
    let x1 = x0 + Math.cos(angle) * len;
    let y1 = y0 + Math.sin(angle) * len;
    if (!ctx.isPointInPath(brainPath, x1, y1)) {
      let lo = 0, hi = len;
      for (let k = 0; k < 10; k++) {
        const m = (lo + hi) / 2;
        if (ctx.isPointInPath(brainPath, x0 + Math.cos(angle) * m, y0 + Math.sin(angle) * m)) lo = m;
        else hi = m;
      }
      len = lo * 0.80;
      x1  = x0 + Math.cos(angle) * len;
      y1  = y0 + Math.sin(angle) * len;
      if (len < MIN_LEN) return null;
    }

    // Organic curve: random perpendicular control-point offset
    const perp  = angle + Math.PI / 2;
    const curve = (Math.random() - 0.5) * len * 0.28;
    const cpx   = (x0 + x1) / 2 + Math.cos(perp) * curve;
    const cpy   = (y0 + y1) / 2 + Math.sin(perp) * curve;

    const hue   = posToHue(x1, y1, bCx, bCy);
    const width = Math.max(0.3, TRUNK_WIDTH * Math.pow(0.72, depth));

    const b: Branch = {
      x0, y0, x1, y1, cpx, cpy, hue, width,
      progress: 0,
      active:   parent === null,   // depth-0 start immediately
      done:     false,
      isLeaf:   false,
      children: [],
    };
    if (parent) parent.children.push(b);
    branches.push(b);

    const nKids  = depth < 3 ? 2 : (Math.random() < 0.68 ? 2 : 1);
    const spread = SPREAD_BASE - depth * 0.028;
    let   hasKid = false;

    for (let i = 0; i < nKids; i++) {
      const off    = nKids === 1 ? 0 : (i / (nKids - 1) - 0.5) * spread;
      const jitter = (Math.random() - 0.5) * 0.10;
      const child  = grow(x1, y1, angle + off + jitter,
                          len * (LEN_DECAY + (Math.random() - 0.5) * 0.10),
                          depth + 1, b);
      if (child) hasKid = true;
    }
    b.isLeaf = !hasKid;
    return b;
  }

  // ── Draw bezier up to fraction t (de Casteljau split) ─────────────
  function strokeTo(
    x0: number, y0: number, cpx: number, cpy: number,
    x1: number, y1: number, t: number
  ) {
    if (t <= 0) return;
    let ex = x1, ey = y1, ecx = cpx, ecy = cpy;
    if (t < 1) {
      const q0x = x0  + (cpx - x0)  * t;
      const q0y = y0  + (cpy - y0)  * t;
      const q1x = cpx + (x1  - cpx) * t;
      const q1y = cpy + (y1  - cpy) * t;
      ex  = q0x + (q1x - q0x) * t;
      ey  = q0y + (q1y - q0y) * t;
      ecx = q0x; ecy = q0y;
    }
    ctx.moveTo(x0, y0);
    ctx.quadraticCurveTo(ecx, ecy, ex, ey);
  }

  // ── Render loop ───────────────────────────────────────────────────
  function draw() {
    ctx.clearRect(0, 0, W, H);
    ctx.lineCap = 'round';

    for (const b of branches) {
      if (!b.active) continue;

      if (!b.done) {
        b.progress = Math.min(1, b.progress + DRAW_SPEED);
        // Cascade: activate children once parent is 85% drawn
        if (b.progress >= 0.85) {
          for (const c of b.children) c.active = true;
        }
        if (b.progress >= 1) b.done = true;
      }

      // Vivid lines — deeper branches are lighter and more saturated
      const sat = Math.min(98, 72 + b.depth * 3);
      const lum = Math.min(74, 50 + b.depth * 3);
      ctx.beginPath();
      ctx.lineWidth   = b.width;
      ctx.strokeStyle = `hsl(${b.hue.toFixed(0)}, ${sat}%, ${lum}%)`;
      strokeTo(b.x0, b.y0, b.cpx, b.cpy, b.x1, b.y1, b.progress);
      ctx.stroke();

      // Glowing dot at each leaf tip when complete
      if (b.done && b.isLeaf) {
        const r = Math.max(2.2, b.width * 1.6);
        ctx.beginPath();
        ctx.fillStyle = `hsl(${b.hue.toFixed(0)}, 90%, 74%)`;
        ctx.arc(b.x1, b.y1, r, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    // Loop: pause then redraw from scratch
    if (branches.length > 0 && branches.every(b => b.done)) {
      if (doneAt < 0) doneAt = performance.now();
      if (performance.now() - doneAt > RESTART_MS) { init(); return; }
    }

    raf = requestAnimationFrame(draw);
  }

  // ── Init ─────────────────────────────────────────────────────────
  function init() {
    cancelAnimationFrame(raf);
    branches = [];
    doneAt   = -1;

    W = canvas.offsetWidth;
    H = canvas.offsetHeight;
    canvas.width  = W;
    canvas.height = H;

    brainPath = makeBrainPath(W, H);
    bCx = W * 0.50;
    bCy = H * 0.44;

    // Brainstem: top of brainstem column, just inside the main brain mass
    const stemX = W * 0.50 + W * 0.43 * 0.20;  // ≈ W * 0.586
    const stemY = H * 0.44 + H * 0.41 * 0.68;  // ≈ H * 0.719

    // Fan of primary branches: upper-left (occipital) → right (temporal/frontal)
    const aMin    = -Math.PI * 0.94;   // ≈ −169°
    const aMax    =  Math.PI * 0.13;   // ≈ +23°
    const initLen = Math.min(W, H) * 0.33;

    for (let i = 0; i < NUM_PRIMARY; i++) {
      const t = i / (NUM_PRIMARY - 1);
      grow(stemX, stemY, aMin + (aMax - aMin) * t, initLen, 0, null);
    }

    draw();
  }

  // ── Resize ───────────────────────────────────────────────────────
  let rsTimer: ReturnType<typeof setTimeout>;
  new ResizeObserver(() => {
    clearTimeout(rsTimer);
    rsTimer = setTimeout(init, 150);
  }).observe(canvas);

  init();
})();
</script>

<style>
  .brain-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
