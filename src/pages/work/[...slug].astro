---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('work');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <article>

    <header class="project-header">
      <div class="container">
        <div class="project-header__meta">
          <a class="project-header__back" href="/work">← All projects</a>
          <span class="project-header__year">{project.data.year}</span>
          {project.data.tags?.map((tag: string) => (
            <span class="chip chip--inverted">{tag}</span>
          ))}
        </div>
        <h1 class="project-header__title">{project.data.title}</h1>
        <p class="project-header__desc">{project.data.description}</p>

        {(project.data.url || project.data.repoUrl) && (
          <div class="project-header__links">
            {project.data.url && (
              <a
                class="btn btn--primary"
                href={project.data.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                View live ↗
              </a>
            )}
            {project.data.repoUrl && (
              <a
                class="btn btn--outline"
                href={project.data.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                Source code ↗
              </a>
            )}
          </div>
        )}
      </div>
    </header>

    <div class="container">
      <div class="prose">
        <Content />
      </div>
    </div>

  </article>
</BaseLayout>

<style>
  .project-header {
    background: var(--color-navy-900);
    padding-block: var(--space-12) var(--space-10);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    margin-bottom: var(--space-12);
  }

  .project-header__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  .project-header__back {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.15s ease;
    margin-right: var(--space-1);
  }
  .project-header__back:hover { color: rgba(255, 255, 255, 0.9); }

  .project-header__year {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: rgba(255, 255, 255, 0.38);
    font-variant-numeric: tabular-nums;
  }

  .chip--inverted {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-navy-300);
    background: rgba(79, 131, 234, 0.15);
    padding: 2px var(--space-2);
    border-radius: var(--radius-pill);
  }

  .project-header__title {
    font-size: clamp(var(--text-2xl), 4.5vw, var(--text-5xl));
    font-weight: var(--weight-bold);
    color: #fff;
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
    max-width: 760px;
    margin-bottom: var(--space-4);
  }

  .project-header__desc {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.52);
    max-width: 640px;
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  .project-header__links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-5);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-md);
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    border: 1px solid transparent;
  }

  .btn--primary { background: var(--color-navy-500); color: #fff; }
  .btn--primary:hover { background: var(--color-navy-400); color: #fff; }

  .btn--outline {
    background: transparent;
    color: rgba(255, 255, 255, 0.65);
    border-color: rgba(255, 255, 255, 0.2);
  }
  .btn--outline:hover {
    background: rgba(255, 255, 255, 0.07);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.38);
  }

  /* Prose — reuse same pattern as blog post */
  .prose {
    max-width: 720px;
    padding-bottom: var(--space-24);
  }

  .prose :global(h2) {
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .prose :global(h3) {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .prose :global(p) {
    margin-bottom: var(--space-5);
    line-height: var(--leading-relaxed);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-5);
    list-style: revert;
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
    line-height: var(--leading-relaxed);
  }

  .prose :global(a) {
    color: var(--color-navy-500);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
