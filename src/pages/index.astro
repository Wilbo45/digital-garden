---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="Home">

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="container">
      <div class="hero__eyebrow">Digital Garden</div>
      <h1 class="hero__headline">
        Writing, experiments,<br />
        and visual ideas.
      </h1>
      <p class="hero__sub">
        A personal space for long-form thinking, interactive web
        applications, and information graphics.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="/blog">Read the blog</a>
        <a class="btn btn--outline" href="/about">About me</a>
      </div>
    </div>
  </section>

  <!-- ── Recent posts ── -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title">Recent writing</h2>
        <a class="section__more" href="/blog">All posts →</a>
      </div>

      {posts.length === 0 ? (
        <p class="empty-state">No posts yet — check back soon.</p>
      ) : (
        <div class="card-grid">
          {posts.map(post => (
            <a class="card" href={`/blog/${post.slug}`}>
              <div class="card__meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                {post.data.tags?.map((tag: string) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
              <h3 class="card__title">{post.data.title}</h3>
              <p class="card__desc">{post.data.description}</p>
              <span class="card__cta">Read more →</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    background: var(--color-navy-900);
    padding-block: clamp(var(--space-16), 10vw, var(--space-32)) clamp(var(--space-12), 8vw, var(--space-24));
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 90% 70% at 65% 40%,
      rgba(0, 65, 163, 0.45) 0%,
      transparent 65%
    );
    pointer-events: none;
  }

  .hero .container { position: relative; z-index: 1; }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-navy-300);
    border: 1px solid rgba(79, 131, 234, 0.35);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-6);
  }

  .hero__headline {
    font-size: clamp(var(--text-3xl), 6vw, var(--text-6xl));
    font-weight: var(--weight-bold);
    color: #fff;
    line-height: var(--leading-none);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-6);
  }

  .hero__sub {
    font-size: clamp(var(--text-base), 2vw, var(--text-lg));
    color: rgba(255, 255, 255, 0.58);
    max-width: 520px;
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-10);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-md);
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    border: 1px solid transparent;
  }

  .btn--primary {
    background: var(--color-navy-500);
    color: #fff;
  }
  .btn--primary:hover {
    background: var(--color-navy-400);
    color: #fff;
  }

  .btn--outline {
    background: transparent;
    color: rgba(255, 255, 255, 0.68);
    border-color: rgba(255, 255, 255, 0.2);
  }
  .btn--outline:hover {
    background: rgba(255, 255, 255, 0.07);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.38);
  }

  /* ── Section ── */
  .section { padding-block: var(--space-16); }

  .section__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .section__title {
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
  }

  .section__more {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-navy-500);
    white-space: nowrap;
  }

  /* ── Card grid ── */
  .card-grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    background: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }

  .card:hover {
    border-color: var(--color-navy-300);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .card__meta time {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
  }

  .chip {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-navy-500);
    background: var(--color-navy-50);
    padding: 2px var(--space-2);
    border-radius: var(--radius-pill);
  }

  .card__title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    line-height: var(--leading-snug);
  }

  .card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    line-height: var(--leading-relaxed);
    flex-grow: 1;
  }

  .card__cta {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-navy-500);
    margin-top: var(--space-1);
  }

  .empty-state {
    padding: var(--space-12);
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
  }
</style>
