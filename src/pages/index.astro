---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = (await getCollection('work'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="Home">

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="container">
      <div class="hero__eyebrow">Digital Garden</div>
      <h1 class="hero__headline">
        Writing, experiments,<br />
        and visual ideas.
      </h1>
      <p class="hero__sub">
        A personal space for long-form thinking, interactive web
        applications, and information graphics.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="/blog">Read the blog</a>
        <a class="btn btn--outline" href="/about">About me</a>
      </div>
    </div>
  </section>

  <!-- ── Content columns ── -->
  <section class="section">
    <div class="container">
      <div class="columns">

        <!-- Blog column -->
        <div class="col">
          <div class="col__header">
            <h2 class="col__title">Writing</h2>
            <a class="col__more" href="/blog">All posts →</a>
          </div>
          {posts.length === 0 ? (
            <p class="empty-state">No posts yet.</p>
          ) : (
            <ol class="entry-list" role="list">
              {posts.map(post => (
                <li>
                  <a class="entry" href={`/blog/${post.slug}`}>
                    <span class="entry__label">
                      <time datetime={post.data.pubDate.toISOString()}>
                        {formatDate(post.data.pubDate)}
                      </time>
                      {post.data.tags?.map((tag: string) => (
                        <span class="chip">{tag}</span>
                      ))}
                    </span>
                    <span class="entry__title">{post.data.title}</span>
                  </a>
                </li>
              ))}
            </ol>
          )}
        </div>

        <!-- Divider -->
        <div class="col-divider" aria-hidden="true"></div>

        <!-- Work column -->
        <div class="col">
          <div class="col__header">
            <h2 class="col__title">Work</h2>
            <a class="col__more" href="/work">All projects →</a>
          </div>
          {projects.length === 0 ? (
            <p class="empty-state">No projects yet.</p>
          ) : (
            <ol class="entry-list" role="list">
              {projects.map(project => (
                <li>
                  <a class="entry" href={`/work/${project.slug}`}>
                    <span class="entry__label">
                      <span class="entry__year">{project.data.year}</span>
                      {project.data.tags?.map((tag: string) => (
                        <span class="chip">{tag}</span>
                      ))}
                    </span>
                    <span class="entry__title">{project.data.title}</span>
                  </a>
                </li>
              ))}
            </ol>
          )}
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    background: var(--color-navy-900);
    padding-block: clamp(var(--space-16), 10vw, var(--space-32)) clamp(var(--space-12), 8vw, var(--space-24));
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 90% 70% at 65% 40%,
      rgba(0, 65, 163, 0.45) 0%,
      transparent 65%
    );
    pointer-events: none;
  }

  .hero .container { position: relative; z-index: 1; }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-navy-300);
    border: 1px solid rgba(79, 131, 234, 0.35);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-6);
  }

  .hero__headline {
    font-size: clamp(var(--text-3xl), 6vw, var(--text-6xl));
    font-weight: var(--weight-bold);
    color: #fff;
    line-height: var(--leading-none);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-6);
  }

  .hero__sub {
    font-size: clamp(var(--text-base), 2vw, var(--text-lg));
    color: rgba(255, 255, 255, 0.58);
    max-width: 520px;
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-10);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-md);
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    border: 1px solid transparent;
  }

  .btn--primary {
    background: var(--color-navy-500);
    color: #fff;
  }
  .btn--primary:hover {
    background: var(--color-navy-400);
    color: #fff;
  }

  .btn--outline {
    background: transparent;
    color: rgba(255, 255, 255, 0.68);
    border-color: rgba(255, 255, 255, 0.2);
  }
  .btn--outline:hover {
    background: rgba(255, 255, 255, 0.07);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.38);
  }

  /* ── Section ── */
  .section { padding-block: var(--space-16); }

  /* ── Two-column layout ── */
  .columns {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 0 var(--space-12);
    align-items: start;
  }

  .col-divider {
    background: var(--color-border);
    align-self: stretch;
  }

  /* ── Column header ── */
  .col__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border-strong);
    margin-bottom: var(--space-1);
  }

  .col__title {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .col__more {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-navy-500);
    white-space: nowrap;
    text-decoration: none;
  }

  .col__more:hover { color: var(--color-navy-400); }

  /* ── Entry list ── */
  .entry-list {
    display: flex;
    flex-direction: column;
  }

  .entry {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: background 0.1s ease;
  }

  .entry:last-child { border-bottom: none; }

  .entry:hover .entry__title {
    color: var(--color-navy-500);
  }

  .entry__label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .entry__label time,
  .entry__year {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .chip {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-navy-500);
    background: var(--color-navy-50);
    padding: 1px var(--space-2);
    border-radius: var(--radius-pill);
  }

  .entry__title {
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    line-height: var(--leading-snug);
    transition: color 0.15s ease;
  }

  .empty-state {
    padding: var(--space-8);
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    margin-top: var(--space-4);
  }

  /* ── Responsive: stack on mobile ── */
  @media (max-width: 640px) {
    .columns {
      grid-template-columns: 1fr;
      gap: var(--space-12) 0;
    }

    .col-divider { display: none; }
  }
</style>
