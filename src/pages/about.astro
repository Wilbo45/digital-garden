---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="About me — background, what I'm working on, and how to get in touch."
>

  <!-- ── Page header ── -->
  <div class="page-header">
    <div class="container">
      <h1 class="page-header__title">About</h1>
      <p class="page-header__sub">
        Background, current work, and how to reach me.
      </p>
    </div>
  </div>

  <div class="container">
    <div class="about-wrap">

      <!-- ── Bio ── -->
      <section class="about-section">
        <h2 class="about-section__title">Background</h2>
        <div class="prose">
          <p>
            Hi, I'm <strong>D. Gates</strong>. This is my digital garden — a place
            where I write about things I find interesting, build small interactive
            experiments, and explore ideas through data visualisation.
          </p>
          <p>
            I'm interested in the intersection of design and technology: how
            information is structured, how it's communicated visually, and how
            interactive systems can make complex things legible. I write here when
            I have something worth saying.
          </p>
          <p>
            Update this section with your own background — where you work, what
            you've built, what draws you to the work you do.
          </p>
        </div>
      </section>

      <hr class="about-divider" />

      <!-- ── Now ── -->
      <section class="about-section">
        <h2 class="about-section__title">Now</h2>
        <div class="prose">
          <p>
            Right now I'm building this site — establishing the foundation for
            writing regularly and shipping interactive work publicly.
          </p>
          <p>Things on my mind at the moment:</p>
          <ul>
            <li>Data visualisation and information graphics</li>
            <li>Writing clearly about technical subjects</li>
            <li>Building small, focused tools</li>
          </ul>
          <p>
            <em>
              The /now page idea comes from <a href="https://nownownow.com" target="_blank" rel="noopener">nownownow.com</a>.
              Update this whenever things change.
            </em>
          </p>
        </div>
      </section>

      <hr class="about-divider" />

      <!-- ── Connect ── -->
      <section class="about-section">
        <h2 class="about-section__title">Connect</h2>
        <ul class="connect-list" role="list">
          <li>
            <a class="connect-item" href="https://github.com/Wilbo45" target="_blank" rel="noopener noreferrer">
              <span class="connect-item__label">GitHub</span>
              <span class="connect-item__value">github.com/Wilbo45</span>
            </a>
          </li>
        </ul>
      </section>

    </div>
  </div>

</BaseLayout>

<style>
  .page-header {
    background: var(--color-navy-900);
    padding-block: var(--space-16) var(--space-12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .page-header__title {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: var(--weight-bold);
    color: #fff;
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-3);
  }

  .page-header__sub {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.5);
  }

  .about-wrap {
    max-width: 720px;
    padding-block: var(--space-12) var(--space-24);
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .about-section__title {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .about-divider {
    border: none;
    border-top: 1px solid var(--color-border);
  }

  /* Prose within about page */
  .prose p {
    margin-bottom: var(--space-4);
    color: var(--color-text);
    line-height: var(--leading-relaxed);
  }

  .prose p:last-child { margin-bottom: 0; }

  .prose strong { font-weight: var(--weight-semibold); }

  .prose em { font-style: italic; color: var(--color-text-subtle); }

  .prose ul {
    padding-left: var(--space-5);
    margin-block: var(--space-3) var(--space-4);
    list-style: disc;
  }

  .prose li {
    margin-bottom: var(--space-2);
    color: var(--color-text);
    line-height: var(--leading-relaxed);
  }

  .prose a {
    color: var(--color-navy-500);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Connect list */
  .connect-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .connect-item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .connect-item:hover {
    border-color: var(--color-navy-300);
    box-shadow: var(--shadow-sm);
  }

  .connect-item__label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    width: 80px;
    flex-shrink: 0;
  }

  .connect-item__value {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
  }
</style>
