---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article>

    <header class="post-header">
      <div class="container">
        <div class="post-header__meta">
          <a class="post-header__back" href="/blog">← All posts</a>
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
          {post.data.tags?.map((tag: string) => (
            <a class="chip chip--inverted" href={`/blog/tags/${tag}`}>{tag}</a>
          ))}
        </div>
        <h1 class="post-header__title">{post.data.title}</h1>
        {post.data.description && (
          <p class="post-header__desc">{post.data.description}</p>
        )}
      </div>
    </header>

    <div class="container">
      <div class="prose">
        <Content />
      </div>
    </div>

  </article>
</BaseLayout>

<style>
  /* ── Post header ── */
  .post-header {
    background: var(--color-navy-900);
    padding-block: var(--space-12) var(--space-10);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    margin-bottom: var(--space-12);
  }

  .post-header__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  .post-header__back {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.15s ease;
    margin-right: var(--space-1);
  }
  .post-header__back:hover { color: rgba(255, 255, 255, 0.9); }

  .post-header__meta time {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: rgba(255, 255, 255, 0.38);
  }

  .chip--inverted {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-navy-300);
    background: rgba(79, 131, 234, 0.15);
    padding: 2px var(--space-2);
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .chip--inverted:hover { background: rgba(79, 131, 234, 0.28); }

  .post-header__title {
    font-size: clamp(var(--text-2xl), 4.5vw, var(--text-5xl));
    font-weight: var(--weight-bold);
    color: #fff;
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
    max-width: 760px;
    margin-bottom: var(--space-4);
  }

  .post-header__desc {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.52);
    max-width: 640px;
    line-height: var(--leading-relaxed);
  }

  /* ── Prose ── */
  .prose {
    max-width: 720px;
    padding-bottom: var(--space-24);
  }

  .prose :global(h2) {
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .prose :global(h3) {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .prose :global(h4) {
    font-size: var(--text-lg);
    font-weight: var(--weight-medium);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  .prose :global(p) {
    margin-bottom: var(--space-5);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-5);
    list-style: revert;
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
    line-height: var(--leading-relaxed);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-navy-500);
    padding-left: var(--space-5);
    margin-block: var(--space-8);
    color: var(--color-text-subtle);
    font-size: var(--text-lg);
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: var(--space-12);
  }

  .prose :global(a) {
    color: var(--color-navy-500);
    text-decoration: underline;
    text-decoration-color: rgba(0, 65, 163, 0.35);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s ease;
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--color-navy-500);
  }

  .prose :global(img) {
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    margin-block: var(--space-8);
    box-shadow: var(--shadow-sm);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin-block: var(--space-8);
  }

  .prose :global(th) {
    text-align: left;
    font-weight: var(--weight-semibold);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface-2);
    border-bottom: 2px solid var(--color-border-strong);
  }

  .prose :global(td) {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }
</style>
